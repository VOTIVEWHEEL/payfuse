{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@payfuse/core": ["../core/src"],
      "@payfuse/paystack": ["../providers/paystack/src"],
      "@payfuse/flutterwave": ["../providers/flutterwave/src"],
      "@payfuse/mtn-momo": ["../providers/mtn-momo/src"],
      "@payfuse/interswitch": ["../providers/interswitch/src"],
      "@payfuse/opay": ["../providers/opay/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
