# ─── Server ──────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# A strong random secret used to authenticate API requests
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYFUSE_API_KEY=your-strong-random-api-key

# ─── Orchestration ───────────────────────────────────────────
PAYFUSE_STRATEGY=priority
PAYFUSE_RETRIES=2
PAYFUSE_TIMEOUT=30000

# ─── Paystack ────────────────────────────────────────────────
PAYSTACK_ENABLED=true
PAYSTACK_PRIORITY=1
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# ─── Flutterwave ─────────────────────────────────────────────
FLUTTERWAVE_ENABLED=false
FLUTTERWAVE_PRIORITY=2
FLW_SECRET_KEY=FLWSECK_TEST_your_flw_secret_key
FLW_SECRET_HASH=your_flw_secret_hash

# ─── MTN MoMo ────────────────────────────────────────────────
MTN_MOMO_ENABLED=false
MTN_MOMO_PRIORITY=3
MTN_API_USER_ID=your_mtn_api_user_id
MTN_API_KEY=your_mtn_api_key
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_SECRET=your_mtn_api_secret
MTN_ENVIRONMENT=sandbox

# ─── Interswitch ─────────────────────────────────────────────
INTERSWITCH_ENABLED=false
INTERSWITCH_PRIORITY=4
INTERSWITCH_CLIENT_ID=your_interswitch_client_id
INTERSWITCH_CLIENT_SECRET=your_interswitch_client_secret
INTERSWITCH_ENVIRONMENT=sandbox

# ─── OPay ────────────────────────────────────────────────────
OPAY_ENABLED=false
OPAY_PRIORITY=5
OPAY_MERCHANT_ID=your_opay_merchant_id
OPAY_APP_SECRET=your_opay_app_secret
OPAY_ENVIRONMENT=sandbox
