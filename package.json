{
  "name": "payfuse",
  "description": "Unified payment orchestration layer for African payment providers",
  "private": true,
  "license": "MIT",
  "author": "Joshua Adesanya",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/payfuse"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "packages/*",
    "packages/providers/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf packages/*/dist",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'packages/**/*.ts'",
    "lint:fix": "eslint 'packages/**/*.ts' --fix",
    "format": "prettier --write 'packages/**/*.ts'"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0"
  }
}
